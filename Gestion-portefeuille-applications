<!DOCTYPE html>
<html lang="fr">
<head>
  <meta charset="UTF-8" />
  <title>Executive IT — Portefeuille Applicatif</title>
  <style>
    @import url('https://fonts.googleapis.com/css2?family=Inter:wght@300;400;600;700&family=Playfair+Display:wght@700&display=swap');

    :root {
      --navy: #0a192f;
      --gold: #c5a059;
      --slate: #64748b;
      --bg: #f8fafc;
      --white: #ffffff;
      --border: #e2e8f0;
      --invest: #10b981;
      --modernize: #f59e0b;
      --replace: #ef4444;
    }

    * { box-sizing: border-box; margin: 0; padding: 0; }
    body { font-family: 'Inter', sans-serif; background: var(--bg); color: var(--navy); display: flex; }

    /* Sidebar Corporate */
    .sidebar { width: 280px; height: 100vh; background: var(--navy); color: white; position: sticky; top: 0; padding: 40px 0; }
    .logo { padding: 0 30px 30px; border-bottom: 1px solid rgba(255,255,255,0.1); }
    .logo h1 { font-family: 'Playfair Display', serif; font-size: 22px; }
    .logo span { color: var(--gold); font-size: 10px; text-transform: uppercase; letter-spacing: 2px; display: block; }

    .nav-item { padding: 15px 30px; font-size: 13px; cursor: pointer; color: #cbd5e1; transition: 0.3s; border-left: 3px solid transparent; }
    .nav-item.active { background: rgba(255,255,255,0.05); color: white; border-left-color: var(--gold); font-weight: 600; }

    /* Main */
    .main { flex: 1; padding: 60px; max-width: 1300px; }
    .header { display: flex; justify-content: space-between; align-items: flex-end; margin-bottom: 40px; border-bottom: 2px solid var(--navy); padding-bottom: 20px; }
    .header h2 { font-family: 'Playfair Display', serif; font-size: 32px; }

    /* Matrix 2x2 Strategy */
    .panel { background: var(--white); border: 1px solid var(--border); padding: 30px; margin-bottom: 30px; }
    .panel-title { font-family: 'Playfair Display', serif; font-size: 20px; margin-bottom: 25px; border-left: 3px solid var(--gold); padding-left: 15px; }

    .matrix-portfolio {
      display: grid;
      grid-template-columns: 40px 1fr 1fr;
      grid-template-rows: 1fr 1fr 40px;
      gap: 15px;
      height: 450px;
    }
    .axis-y { writing-mode: vertical-lr; transform: rotate(180deg); text-align: center; font-size: 11px; font-weight: 700; color: var(--slate); text-transform: uppercase; }
    .axis-x { grid-column: 2 / 4; text-align: center; font-size: 11px; font-weight: 700; color: var(--slate); text-transform: uppercase; padding-top: 15px; }
    
    .cell { border: 1px solid var(--border); padding: 20px; display: flex; flex-direction: column; justify-content: space-between; }
    .cell-head { font-size: 10px; font-weight: 800; text-transform: uppercase; letter-spacing: 1px; }
    
    .q-invest { background: rgba(16, 185, 129, 0.03); border-top: 4px solid var(--invest); }
    .q-opti { background: rgba(197, 160, 89, 0.03); border-top: 4px solid var(--gold); }
    .q-mod { background: rgba(245, 158, 11, 0.03); border-top: 4px solid var(--modernize); }
    .q-rep { background: rgba(239, 68, 68, 0.03); border-top: 4px solid var(--replace); }

    /* Successor Info */
    .successor-grid { display: grid; grid-template-columns: 1.5fr 1fr; gap: 30px; }
    .app-item { padding: 12px 0; border-bottom: 1px solid var(--border); display: flex; justify-content: space-between; align-items: center; }
    .app-name { font-size: 13px; font-weight: 600; }
    .successor-tag { font-size: 10px; background: #f1f5f9; padding: 4px 8px; border: 1px solid var(--border); color: var(--navy); font-weight: 700; }

  </style>
</head>
<body>

  <nav class="sidebar">
    <div class="logo">
      <h1>Executive IT</h1>
      <span>Architecture & Gouvernance</span>
    </div>
    <div class="nav-item">Vue Stratégique</div>
    <div class="nav-item active">Portefeuille Apps</div>
    <div class="nav-item">TRM — Risques</div>
    <div class="nav-item">Finance IT</div>
    <div class="nav-item">Conformité & Data</div>
    <div class="nav-item">Flux & Intégration</div>
    <div class="nav-item">Sourcing & Vendors</div>
  </nav>

  <main class="main">
    <header class="header">
      <h2>Portefeuille Applicatif</h2>
      <div style="font-size: 12px; color: var(--slate);">VALEUR FONCTIONNELLE VS TECHNIQUE</div>
    </header>

    <div class="panel">
      <div class="panel-title">Matrice d'Arbitrage Stratégique</div>
      <div class="matrix-portfolio">
        <div class="axis-y">Capacité Fonctionnelle (Valeur Métier)</div>
        
        <div class="cell q-invest">
          <span class="cell-head" style="color: var(--invest)">Investir / Étendre</span>
          <p style="font-size: 11px; color: var(--slate);">Applications à forte valeur et socle technique sain.</p>
        </div>
        
        <div class="cell q-opti">
          <span class="cell-head" style="color: var(--gold)">Optimiser / Sécuriser</span>
          <p style="font-size: 11px; color: var(--slate);">Valeur métier élevée mais dette technique à traiter.</p>
        </div>

        <div class="cell q-mod">
          <span class="cell-head" style="color: var(--modernize)">Moderniser / Consolider</span>
          <p style="font-size: 11px; color: var(--slate);">Base saine mais couverture fonctionnelle limitée.</p>
        </div>

        <div class="cell q-rep">
          <span class="cell-head" style="color: var(--replace)">Remplacer / Retirer</span>
          <p style="font-size: 11px; color: var(--slate);">Candidats prioritaires pour la trajectoire de succession.</p>
        </div>

        <div class="axis-x">Capacité Technique (Soutenabilité)</div>
      </div>
    </div>

    <div class="successor-grid">
      <div class="panel">
        <div class="panel-title">Trajectoires de Succession</div>
        <div class="app-item">
          <span class="app-name">Legacy ERP Financials</span>
          <span class="successor-tag">Cible : Cloud S/4HANA</span>
        </div>
        <div class="app-item">
          <span class="app-name">On-Prem CRM V1</span>
          <span class="successor-tag">Cible : Salesforce Core</span>
        </div>
        <div class="app-item">
          <span class="app-name">Custom Billing Tool</span>
          <span class="successor-tag">Cible : SaaS Billing Engine</span>
        </div>
      </div>

      <div class="panel">
        <div class="panel-title">Indicateurs de Santé</div>
        <div style="margin-bottom: 20px;">
          <div style="display: flex; justify-content: space-between; font-size: 12px; margin-bottom: 5px;">
            <span>Criticité Métier (Haut)</span>
            <strong>42%</strong>
          </div>
          <div style="height: 6px; background: #f1f5f9; border-radius: 3px; overflow: hidden;">
            <div style="width: 42%; height: 100%; background: var(--navy);"></div>
          </div>
        </div>
        <div>
          <div style="display: flex; justify-content: space-between; font-size: 12px; margin-bottom: 5px;">
            <span>Obsolescence Technique</span>
            <strong style="color: var(--replace);">15%</strong>
          </div>
          <div style="height: 6px; background: #f1f5f9; border-radius: 3px; overflow: hidden;">
            <div style="width: 15%; height: 100%; background: var(--replace);"></div>
          </div>
        </div>
      </div>
    </div>
  </main>
</body>
</html>
