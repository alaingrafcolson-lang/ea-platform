<!DOCTYPE html>
<html lang="fr">
<head>
  <meta charset="UTF-8" />
  <title>Executive IT — Finance & Performance</title>
  <style>
    @import url('https://fonts.googleapis.com/css2?family=Inter:wght@300;400;600;700&family=Playfair+Display:wght@700&display=swap');

    :root {
      --navy: #0a192f;
      --gold: #c5a059;
      --slate: #64748b;
      --bg: #f8fafc;
      --white: #ffffff;
      --border: #e2e8f0;
      --positive: #10b981;
      --negative: #ef4444;
    }

    * { box-sizing: border-box; margin: 0; padding: 0; }
    body { font-family: 'Inter', sans-serif; background: var(--bg); color: var(--navy); display: flex; }

    /* Sidebar Corporate */
    .sidebar { width: 280px; height: 100vh; background: var(--navy); color: white; position: sticky; top: 0; padding: 40px 0; }
    .logo { padding: 0 30px 30px; border-bottom: 1px solid rgba(255,255,255,0.1); }
    .logo h1 { font-family: 'Playfair Display', serif; font-size: 22px; }
    .logo span { color: var(--gold); font-size: 10px; text-transform: uppercase; letter-spacing: 2px; display: block; }

    .nav-item { padding: 15px 30px; font-size: 13px; cursor: pointer; color: #cbd5e1; transition: 0.3s; border-left: 3px solid transparent; }
    .nav-item.active { background: rgba(255,255,255,0.05); color: white; border-left-color: var(--gold); font-weight: 600; }

    /* Main */
    .main { flex: 1; padding: 60px; max-width: 1300px; }
    .header { display: flex; justify-content: space-between; align-items: flex-end; margin-bottom: 40px; border-bottom: 2px solid var(--navy); padding-bottom: 20px; }
    .header h2 { font-family: 'Playfair Display', serif; font-size: 32px; }

    /* Financial Grid */
    .panel { background: var(--white); border: 1px solid var(--border); padding: 30px; margin-bottom: 30px; }
    .panel-title { font-family: 'Playfair Display', serif; font-size: 20px; margin-bottom: 25px; border-left: 3px solid var(--gold); padding-left: 15px; }

    .finance-stats { display: grid; grid-template-columns: 2fr 1fr; gap: 30px; }

    /* Table */
    .table { width: 100%; border-collapse: collapse; }
    .table th { text-align: left; font-size: 11px; text-transform: uppercase; color: var(--slate); padding: 12px; border-bottom: 2px solid var(--border); }
    .table td { padding: 15px 12px; font-size: 13px; border-bottom: 1px solid var(--border); }
    
    /* Progress Bars */
    .bar-container { display: flex; align-items: center; gap: 10px; }
    .bar-bg { flex: 1; height: 6px; background: #f1f5f9; border-radius: 3px; overflow: hidden; }
    .bar-fill { height: 100%; background: var(--navy); }

    /* Data Viz Donut Mock */
    .chart-container { display: flex; flex-direction: column; align-items: center; justify-content: center; text-align: center; }
    .donut-mock { width: 150px; height: 150px; border-radius: 50%; border: 15px solid var(--navy); border-top-color: var(--gold); display: flex; align-items: center; justify-content: center; margin-bottom: 20px; }
    .donut-text { font-size: 20px; font-weight: 800; }

    /* Action Cards */
    .action-grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: 20px; }
    .action-card { padding: 20px; background: #f8fafc; border: 1px solid var(--border); }
    .action-val { font-size: 24px; font-weight: 800; color: var(--positive); margin: 5px 0; }

  </style>
</head>
<body>

  <nav class="sidebar">
    <div class="logo">
      <h1>Executive IT</h1>
      <span>Architecture & Gouvernance</span>
    </div>
    <div class="nav-item">Vue Stratégique</div>
    <div class="nav-item">Portefeuille Apps</div>
    <div class="nav-item">TRM — Risques</div>
    <div class="nav-item active">Finance IT</div>
    <div class="nav-item">Conformité & Data</div>
    <div class="nav-item">Flux & Intégration</div>
    <div class="nav-item">Sourcing & Vendors</div>
  </nav>

  <main class="main">
    <header class="header">
      <h2>Gestion Financière de l’IT</h2>
      <button style="background: var(--navy); color: white; border: none; padding: 10px 15px; font-size: 11px; font-weight: 700; text-transform: uppercase; cursor: pointer;">Exporter Rapport Financier</button>
    </header>

    <div class="finance-stats">
      <div class="panel">
        <div class="panel-title">Répartition du Budget Annuel (YTD)</div>
        <table class="table">
          <thead>
            <tr>
              <th>Poste de dépense</th>
              <th>Consommation</th>
              <th>Écart / Cible</th>
            </tr>
          </thead>
          <tbody>
            <tr>
              <td><strong>Logiciels & Licences</strong></td>
              <td>
                <div class="bar-container">
                  <div class="bar-bg"><div class="bar-fill" style="width: 72%;"></div></div>
                  <span>72%</span>
                </div>
              </td>
              <td style="color: var(--positive);">-2.4%</td>
            </tr>
            <tr>
              <td><strong>Maintenance (TMA)</strong></td>
              <td>
                <div class="bar-container">
                  <div class="bar-bg"><div class="bar-fill" style="width: 45%; background: var(--gold);"></div></div>
                  <span>45%</span>
                </div>
              </td>
              <td style="color: var(--negative);">+5.1%</td>
            </tr>
            <tr>
              <td><strong>Infrastructure / Cloud</strong></td>
              <td>
                <div class="bar-container">
                  <div class="bar-bg"><div class="bar-fill" style="width: 28%;"></div></div>
                  <span>28%</span>
                </div>
              </td>
              <td style="color: var(--positive);">-1.2%</td>
            </tr>
          </tbody>
        </table>
      </div>

      <div class="panel chart-container">
        <div class="panel-title">Coût Total</div>
        <div class="donut-mock">
          <div class="donut-text">11.6M€</div>
        </div>
        <div style="font-size: 12px; color: var(--slate);">Budget global validé</div>
      </div>
    </div>

    <div class="panel">
      <div class="panel-title">Leviers d'Optimisation Projetés</div>
      <div class="action-grid">
        <div class="action-card">
          <div style="font-size: 10px; font-weight: 700; color: var(--slate); text-transform: uppercase;">Consolidation ERP</div>
          <div class="action-val">450k €</div>
          <p style="font-size: 11px;">Gain via suppression des instances redondantes.</p>
        </div>
        <div class="action-card">
          <div style="font-size: 10px; font-weight: 700; color: var(--slate); text-transform: uppercase;">Cloud FinOps</div>
          <div class="action-val">12%</div>
          <p style="font-size: 11px;">Réduction des ressources sous-utilisées.</p>
        </div>
        <div class="action-card">
          <div style="font-size: 10px; font-weight: 700; color: var(--slate); text-transform: uppercase;">Contrats Vendors</div>
          <div class="action-val">210k €</div>
          <p style="font-size: 11px;">Arbitrage et renégociation stratégique.</p>
        </div>
      </div>
    </div>
  </main>
</body>
</html>
