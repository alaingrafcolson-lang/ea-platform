<!DOCTYPE html>
<html lang="fr">
<head>
  <meta charset="UTF-8" />
  <title>Executive IT — Cybersécurité & Identités</title>
  <style>
    @import url('https://fonts.googleapis.com/css2?family=Inter:wght@300;400;600;700&family=Playfair+Display:wght@700&display=swap');

    :root {
      --navy: #0a192f;
      --gold: #c5a059;
      --slate: #64748b;
      --bg: #f8fafc;
      --white: #ffffff;
      --border: #e2e8f0;
      --shield: #1e40af;
      --danger: #b91c1c;
      --success: #10b981;
    }

    * { box-sizing: border-box; margin: 0; padding: 0; }
    body { font-family: 'Inter', sans-serif; background: var(--bg); color: var(--navy); display: flex; }

    /* Sidebar Corporate */
    .sidebar { width: 280px; height: 100vh; background: var(--navy); color: white; position: sticky; top: 0; padding: 40px 0; }
    .logo { padding: 0 30px 30px; border-bottom: 1px solid rgba(255,255,255,0.1); }
    .logo h1 { font-family: 'Playfair Display', serif; font-size: 22px; }
    .logo span { color: var(--gold); font-size: 10px; text-transform: uppercase; letter-spacing: 2px; display: block; }

    .nav-item { padding: 15px 30px; font-size: 13px; cursor: pointer; color: #cbd5e1; transition: 0.3s; border-left: 3px solid transparent; }
    .nav-item.active { background: rgba(255,255,255,0.05); color: white; border-left-color: var(--gold); font-weight: 600; }

    /* Main */
    .main { flex: 1; padding: 60px; max-width: 1400px; }
    .header { display: flex; justify-content: space-between; align-items: flex-end; margin-bottom: 40px; border-bottom: 2px solid var(--navy); padding-bottom: 20px; }
    .header h2 { font-family: 'Playfair Display', serif; font-size: 32px; }

    /* Layout panels */
    .grid-top { display: grid; grid-template-columns: 2fr 1fr; gap: 30px; margin-bottom: 30px; }
    .panel { background: var(--white); border: 1px solid var(--border); padding: 30px; }
    .panel-title { font-family: 'Playfair Display', serif; font-size: 18px; margin-bottom: 20px; border-left: 4px solid var(--shield); padding-left: 15px; }

    /* Tables */
    .table-cyber { width: 100%; border-collapse: collapse; }
    .table-cyber th { text-align: left; font-size: 10px; text-transform: uppercase; color: var(--slate); padding: 12px; background: #f8fafc; }
    .table-cyber td { padding: 14px 12px; font-size: 12px; border-bottom: 1px solid var(--border); vertical-align: middle; }

    /* Indicators */
    .crit-high { color: var(--danger); font-weight: 700; }
    .crit-med { color: var(--gold); font-weight: 700; }
    .cost-tag { font-family: 'Courier New', monospace; font-weight: 700; color: var(--navy); }
    .dev-note { font-style: italic; color: var(--slate); font-size: 11px; display: block; margin-top: 4px; }
    
    .badge-status { padding: 4px 8px; font-size: 10px; font-weight: 700; border-radius: 2px; text-transform: uppercase; }
    .status-active { background: #dcfce7; color: #166534; }
    .status-progress { background: #fef3c7; color: #92400e; }

    /* Summary cards */
    .summary-grid { display: grid; grid-template-columns: repeat(4, 1fr); gap: 20px; margin-top: 30px; }
    .summary-card { padding: 20px; border: 1px solid var(--border); background: var(--white); border-top: 3px solid var(--gold); }
    .summary-label { font-size: 10px; text-transform: uppercase; color: var(--slate); font-weight: 700; }
    .summary-val { font-size: 20px; font-weight: 700; display: block; margin-top: 5px; }

  </style>
</head>
<body>

  <nav class="sidebar">
    <div class="logo">
      <h1>Executive IT</h1>
      <span>Architecture & Gouvernance</span>
    </div>
    <div class="nav-item">Vue Stratégique</div>
    <div class="nav-item">Portefeuille Apps</div>
    <div class="nav-item">TRM — Risques</div>
    <div class="nav-item">Finance IT</div>
    <div class="nav-item">Conformité & Data</div>
    <div class="nav-item active">Cyber : IAM & Accès</div>
    <div class="nav-item">Sourcing & Vendors</div>
  </nav>

  <main class="main">
    <header class="header">
      <h2>Identity & Access Governance</h2>
      <div style="font-size: 12px; color: var(--slate);">PILOTAGE CRITICITÉ & COÛTS OPÉRATIONNELS</div>
    </header>

    <div class="grid-top">
      <div class="panel">
        <div class="panel-title">Matrice de Gestion des Outils d'Accès</div>
        <table class="table-cyber">
          <thead>
            <tr>
              <th>Outil / Protocole</th>
              <th>Criticité</th>
              <th>Pilotage Annuel</th>
              <th>Retour Services Dev/Sec</th>
              <th>Statut</th>
            </tr>
          </thead>
          <tbody>
            <tr>
              <td><strong>IAM</strong><br><small>Identity Management</small></td>
